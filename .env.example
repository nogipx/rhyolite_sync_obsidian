# --- Auth (REQUIRED) -------------------------------------------------------
# Long random secret clients present as a Bearer token. Generate one with:
#   openssl rand -hex 32
RHYOLITE_SYNC_TOKEN=

# --- TLS -------------------------------------------------------------------
# Hostname clients connect to (wss://SYNC_DOMAIN). Determines the cert Caddy uses:
#   sync.example.com        real Let's Encrypt cert     (needs ports 80+443 public)
#   <your-ip>.sslip.io      real cert, no domain owned  (needs public IP + 80+443)
#   localhost / bare IP     self-signed internal cert   (clients must trust Caddy's root CA)
SYNC_DOMAIN=localhost

# --- Postgres --------------------------------------------------------------
PG_PASSWORD=postgres
PG_SCHEMA=sync

# --- MinIO -----------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
